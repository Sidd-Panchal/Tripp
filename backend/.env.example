# ---------------------------------------------------------
# Trrip AI Backend Environment Variables Template
# Copy this file to '.env' and populate with actual credentials
# Do not commit the '.env' file containing real secrets to Git
# ---------------------------------------------------------

# Server configuration
PORT=5000
NODE_ENV=development

# Database configuration
# - Local MongoDB (development fallback): mongodb://localhost:27017/trrip
# - MongoDB Atlas (production): mongodb+srv://<username>:<password>@cluster.mongodb.net/trrip
MONGO_URI=mongodb://localhost:27017/trrip

# Security & Authentication
# - Generate a strong random key in production (e.g., using 'openssl rand -base64 32')
JWT_SECRET=your_jwt_secret_key_here

# AI Service Configuration
# - Get a key from Google AI Studio (https://aistudio.google.com/)
# - If left empty or invalid, the backend will gracefully run in Mock Mode for testing
GEMINI_API_KEY=your_gemini_api_key_here

# CORS Policies
# - Comma-separated list of allowed origins (e.g. http://localhost:5173,https://trrip.ai)
# - Set to '*' to allow all origins (default in development)
CORS_ALLOWED_ORIGINS=*
